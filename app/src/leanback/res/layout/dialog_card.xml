<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_60"
    android:orientation="vertical">

    <FrameLayout
        android:id="@+id/ll_editText"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/ll_keyboard"
        android:gravity="center">

        <EditText
            android:id="@+id/card_editText"
            android:layout_width="480dp"
            android:layout_height="60dp"
            android:layout_gravity="center"
            android:background="#fff"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:hint="请输入您的兑换码"
            android:paddingStart="10dp"
            android:textSize="20sp"
            tools:ignore="RtlSymmetry" />

        <LinearLayout
            android:id="@+id/iv_code"
            android:layout_marginRight="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="right|bottom"
            android:background="@color/white"
            android:orientation="vertical"
            tools:ignore="RtlHardcoded">

            <ImageView
                android:id="@+id/code"
                android:padding="15dp"
                android:layout_width="150dp"
                android:layout_height="150dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:gravity="center"
                android:text="扫码购买卡密" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/ll_keyboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@drawable/selector_item"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="20dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/btnNumber1"
                style="@style/dialog_cami_style"
                android:tag="1"
                android:text="1" />

            <TextView
                android:id="@+id/btnNumber2"
                style="@style/dialog_cami_style"
                android:tag="2"
                android:text="2" />

            <TextView
                android:id="@+id/btnNumber3"
                style="@style/dialog_cami_style"
                android:tag="3"
                android:text="3" />

            <TextView
                android:id="@+id/cardSend"
                android:layout_width="160dp"
                android:layout_height="50dp"
                android:layout_marginLeft="5dp"
                android:layout_marginRight="5dp"
                android:background="@drawable/selector_item"
                android:clickable="true"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:gravity="center"
                android:text="确认兑换"
                android:textColor="@drawable/cami_textcolor_selector"
                android:textSize="20sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">

            <TextView
                android:id="@+id/btnNumber4"
                style="@style/dialog_cami_style"
                android:tag="4"
                android:text="4" />

            <TextView
                android:id="@+id/btnNumber5"
                style="@style/dialog_cami_style"
                android:tag="5"
                android:text="5" />

            <TextView
                android:id="@+id/btnNumber6"
                style="@style/dialog_cami_style"
                android:tag="6"
                android:text="6" />

            <TextView
                android:id="@+id/delete"
                android:layout_width="160dp"
                android:layout_height="50dp"
                android:layout_marginLeft="5dp"
                android:layout_marginRight="5dp"
                android:background="@drawable/selector_item"
                android:clickable="true"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:gravity="center"
                android:text="←"
                android:textColor="@drawable/cami_textcolor_selector"
                android:textSize="20sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">

            <TextView
                android:id="@+id/btnNumber7"
                style="@style/dialog_cami_style"
                android:tag="7"
                android:text="7" />

            <TextView
                android:id="@+id/btnNumber8"
                style="@style/dialog_cami_style"
                android:tag="8"
                android:text="8" />

            <TextView
                android:id="@+id/btnNumber9"
                style="@style/dialog_cami_style"
                android:tag="9"
                android:text="9" />

            <TextView
                android:id="@+id/btnNumber0"
                style="@style/dialog_cami_style"
                android:tag="0"
                android:text="0" />

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>