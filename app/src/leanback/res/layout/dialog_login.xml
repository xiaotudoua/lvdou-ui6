<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="210dp"
    android:padding="16dp">

    <FrameLayout
        android:id="@+id/flCode"
        android:layout_width="180dp"
        android:layout_height="180dp">

        <ImageView
            android:id="@+id/code"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:scaleType="centerCrop" />

<!--        <ProgressBar-->
<!--            android:id="@+id/mProgressBar"-->
<!--            android:layout_width="120dp"-->
<!--            android:layout_height="120dp"-->
<!--            android:layout_gravity="center"-->
<!--            android:indeterminateBehavior="repeat"-->
<!--            android:indeterminateDrawable="@drawable/progress_loading"-->
<!--            android:indeterminateOnly="true"-->
<!--            android:tag="vod_control_loading" />-->
    </FrameLayout>

    <View
        android:id="@+id/lvDou"
        android:layout_width="1dp"
        android:layout_height="180dp"
        android:layout_toEndOf="@+id/flCode" />

    <TextView
        android:id="@+id/info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_toEndOf="@+id/lvDou"
        android:lineSpacingExtra="4dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:textSize="14sp"
        android:text="请输入账户密码登录/注册\n可使用浏览器或微信扫码进行网页登录" />

    <EditText
        android:id="@+id/user_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/passwd_text"
        android:layout_alignStart="@+id/info"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="10dp"
        android:hint="请输入账号…"
        android:imeOptions="actionDone"
        android:importantForAutofill="no"
        android:inputType="text"
        android:nextFocusDown="@id/passwd_text"
        android:singleLine="true"
        android:textSize="16sp" />

    <EditText
        android:id="@+id/passwd_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/bottom"
        android:layout_alignStart="@+id/info"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="10dp"
        android:hint="请输入密码…"
        android:imeOptions="actionDone"
        android:importantForAutofill="no"
        android:inputType="text"
        android:nextFocusDown="@id/positive"
        android:singleLine="true"
        android:textSize="16sp" />

    <LinearLayout
        android:id="@+id/bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignStart="@+id/info"
        android:layout_alignBottom="@+id/lvDou"
        android:layout_marginEnd="12dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/positive"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:layout_weight="1"
            android:background="@drawable/selector_text"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center"
            android:singleLine="true"
            android:text="登录"
            android:textColor="@color/white"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/negative"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/selector_text"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center"
            android:singleLine="true"
            android:text="注册"
            android:textColor="@color/white"
            android:textSize="14sp" />

    </LinearLayout>
</RelativeLayout>